# collect-jenkins-log.sh — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is intentionally git-ignored to protect credentials.
# Never commit a .env file with real tokens.

# ---------------------------------------------------------------------------
# Jenkins connection (required for api and both modes)
# ---------------------------------------------------------------------------

# Base URL of your Jenkins instance. Include the port if non-standard.
# Examples:
#   http://localhost:8080
#   https://jenkins.example.com
JENKINS_URL=http://localhost:8080

# Jenkins username for a service account with the "Overall/Read" and
# "System log/View" permissions.
JENKINS_USER=

# Jenkins API token for the account above.
# Generate one at: <JENKINS_URL>/user/<username>/configure → API Token
JENKINS_TOKEN=

# ---------------------------------------------------------------------------
# File watching (required for file and both modes)
# ---------------------------------------------------------------------------

# Absolute path to jenkins.log on the Jenkins host filesystem.
# Common locations:
#   /var/log/jenkins/jenkins.log   (Debian/Ubuntu package install)
#   /var/log/jenkins/jenkins.log   (RPM/RHEL package install)
#   <JENKINS_HOME>/jenkins.log     (custom / WAR installs)
JENKINS_LOG_FILE=/var/log/jenkins/jenkins.log

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

# Directory where collected log files are written.
# Will be created automatically if it does not exist.
OUTPUT_DIR=./jenkins-logs

# ---------------------------------------------------------------------------
# Polling
# ---------------------------------------------------------------------------

# How often (in seconds) the API mode polls for new log data,
# and how often the file-polling fallback checks for changes.
# Lower values = faster collection; higher values = less overhead.
POLL_INTERVAL=30
